# Atlas AI — Environment Configuration
# Copy this file to .env and fill in your values

# ── Groq API (Primary AI — Free) ─────────────────────────────────────────────
# Get your free key at: https://console.groq.com/keys
# Alternatively, paste it directly in groq_config.py
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq Model (default: llama-3.3-70b-versatile — free and fast)
GROQ_MODEL=llama-3.3-70b-versatile

# ── OpenAI API (Optional fallback) ───────────────────────────────────────────
# Leave blank — Groq is the primary AI provider
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI Model (default: gpt-4o-mini for cost efficiency)
OPENAI_MODEL=gpt-4o-mini

# Flask Configuration
FLASK_SECRET_KEY=change_this_to_a_random_secret_key_in_production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Model Paths (relative to project root)
INTENT_MODEL_PATH=models/intent_classifier
NER_MODEL_PATH=models/ner_model
EMBEDDINGS_INDEX_PATH=models/faiss_index

# RAG Configuration
RAG_TOP_K=5
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64

# NLP Confidence Thresholds
INTENT_CONFIDENCE_THRESHOLD=0.80
NER_CONFIDENCE_THRESHOLD=0.80

# Session Configuration
SESSION_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/atlas_ai.log
